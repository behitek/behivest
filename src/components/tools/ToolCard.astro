---
export interface Props {
  title: string;
  description: string;
  whenToUse: string;
  href: string;
}

const { title, description, whenToUse, href } = Astro.props;
---

<a
  href={href}
  class="group block rounded-3xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-emerald-200 hover:shadow-lg hover:shadow-emerald-100 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-emerald-900 dark:hover:shadow-none"
>
  <h3
    class="text-xl font-semibold text-gray-900 transition-colors group-hover:text-emerald-700 dark:text-white dark:group-hover:text-emerald-300"
  >
    {title}
  </h3>
  <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
    {description}
  </p>
  <div
    class="mt-5 rounded-2xl border border-dashed border-emerald-200/80 bg-emerald-50/70 p-4 dark:border-emerald-900 dark:bg-emerald-950/20"
  >
    <p
      class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-600 dark:text-emerald-400"
    >
      Nên dùng khi nào
    </p>
    <p class="mt-2 text-sm leading-7 text-gray-700 dark:text-gray-200">
      {whenToUse}
    </p>
  </div>
  <span
    class="mt-5 inline-flex items-center text-sm font-semibold text-emerald-700 transition-transform group-hover:translate-x-1 dark:text-emerald-300"
  >
    Xem công cụ đầy đủ
    <svg
      class="ml-2 h-4 w-4"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </span>
</a>
