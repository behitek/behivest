---
export interface Props {
  eyebrow: string;
  question: string;
  description: string;
  href: string;
}

const { eyebrow, question, description, href } = Astro.props;
---

<a
  href={href}
  class="group rounded-3xl border border-white/70 bg-white/85 p-6 shadow-sm shadow-emerald-100/70 transition-all hover:-translate-y-0.5 hover:border-emerald-200 hover:shadow-lg hover:shadow-emerald-100 dark:border-gray-800 dark:bg-gray-900/85 dark:shadow-none dark:hover:border-emerald-900"
>
  <p
    class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-600 dark:text-emerald-400"
  >
    {eyebrow}
  </p>
  <h3
    class="mt-3 text-xl font-semibold leading-8 text-gray-900 transition-colors group-hover:text-emerald-700 dark:text-white dark:group-hover:text-emerald-300"
  >
    {question}
  </h3>
  <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-300">
    {description}
  </p>
  <span
    class="mt-5 inline-flex items-center text-sm font-semibold text-emerald-700 transition-transform group-hover:translate-x-1 dark:text-emerald-300"
  >
    Xem gợi ý đầu tiên
    <svg
      class="ml-2 h-4 w-4"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </span>
</a>
