---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer
  style="border-top: 1px solid var(--border); background: var(--bg-warm);"
>
  <div class="mx-auto px-4 py-12 sm:px-6 lg:px-8" style="max-width: 1080px;">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
      <!-- Brand -->
      <div class="col-span-1 md:col-span-2">
        <a href={base} class="flex items-center space-x-2">
          <img src={`${base}logo.svg`} alt="Behivest" class="h-8 w-auto" />
        </a>
        <p class="mt-4 text-sm" style="color: var(--text-secondary);">
          Đầu tư dễ hiểu, sinh lời bền vững
        </p>
        <p class="mt-2 text-sm" style="color: var(--text-muted);">
          Behivest cung cấp kiến thức tài chính cá nhân và hướng dẫn đầu tư
          thông minh cho người Việt.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3
          class="mb-4 text-xs font-semibold uppercase tracking-widest"
          style="color: var(--text-muted);"
        >
          Liên kết
        </h3>
        <ul class="space-y-2 text-sm">
          {
            [
              { href: `${base}blog`, label: 'Blog' },
              { href: `${base}faq`, label: 'Từ điển FAQ' },
              { href: `${base}tools`, label: 'Công cụ' },
              { href: `${base}about`, label: 'Giới thiệu' },
              { href: `${base}contact`, label: 'Liên hệ' },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="transition-colors"
                  style="color: var(--text-secondary);"
                  onmouseover="this.style.color='var(--accent)';"
                  onmouseout="this.style.color='var(--text-secondary)';"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Tools -->
      <div>
        <h3
          class="mb-4 text-xs font-semibold uppercase tracking-widest"
          style="color: var(--text-muted);"
        >
          Công cụ
        </h3>
        <ul class="space-y-2 text-sm">
          {
            [
              { href: `${base}tools/compound-interest`, label: 'Tính lãi kép' },
              { href: `${base}tools/sip-calculator`, label: 'Tính SIP' },
              {
                href: `${base}tools/budget-allocator`,
                label: 'Phân bổ ngân sách',
              },
              {
                href: `${base}tools/emergency-fund-planner`,
                label: 'Quỹ khẩn cấp',
              },
              {
                href: `${base}tools/goal-based-contribution`,
                label: 'Mức góp theo mục tiêu',
              },
              {
                href: `${base}tools/investment-comparison`,
                label: 'So sánh đầu tư',
              },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="transition-colors"
                  style="color: var(--text-secondary);"
                  onmouseover="this.style.color='var(--accent)';"
                  onmouseout="this.style.color='var(--text-secondary)';"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t pt-8" style="border-color: var(--border);">
      <p class="text-center text-sm" style="color: var(--text-muted);">
        © {currentYear} Behivest. Tất cả quyền được bảo lưu.
      </p>
    </div>
  </div>
</footer>
