---
// src/components/FeeComparisonChart.astro
// Fee comparison bar chart: mutual fund vs individual stocks
---

<div
  data-component="fee-comparison-chart"
  class="my-8 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-900"
>
  <h3
    class="mb-1 text-center text-base font-semibold text-gray-800 dark:text-gray-100"
  >
    So sánh chi phí giao dịch: Quỹ mở vs Cổ phiếu lẻ
  </h3>
  <p class="mb-3 text-center text-xs text-gray-500 dark:text-gray-400">
    Đầu tư 10 triệu VND · Hover/tap để xem chi tiết
  </p>
  <div class="relative">
    <canvas
      id="feeCanvas"
      class="w-full"
      style="max-height: 320px;"
      aria-label="Biểu đồ so sánh phí giao dịch"
      role="img"></canvas>
    <div
      id="feeTooltip"
      class="pointer-events-none absolute hidden rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm shadow-lg dark:border-gray-600 dark:bg-gray-800"
      style="z-index: 10;"
    >
    </div>
  </div>
</div>

<script>
  interface Bar {
    label: string;
    value: number;
    color: string;
    detail: string;
  }

  const BARS: Bar[] = [
    {
      label: 'Quỹ mở\n(1 lần)',
      value: 1500,
      color: '#10b981',
      detail: 'Phí 0.15% × 10M × 1 lần = 1.500đ',
    },
    {
      label: 'Quỹ mở\n(DCA 12 lần)',
      value: 18000,
      color: '#34d399',
      detail: 'Phí 0.15% × 10M × 12 lần = 18.000đ',
    },
    {
      label: 'Mua 10 cổ\nphiếu lẻ',
      value: 35000,
      color: '#f97316',
      detail: 'Phí môi giới + lưu ký 10 mã ≈ 35.000đ',
    },
    {
      label: 'Mua 20 cổ\nphiếu lẻ',
      value: 70000,
      color: '#ef4444',
      detail: 'Phí môi giới + lưu ký 20 mã ≈ 70.000đ',
    },
  ];

  const container = document.querySelector(
    '[data-component="fee-comparison-chart"]'
  ) as HTMLElement;
  if (!container) throw new Error('FeeComparisonChart container not found');
  const canvas = container.querySelector('#feeCanvas') as HTMLCanvasElement;
  const tooltip = container.querySelector('#feeTooltip') as HTMLDivElement;

  const ctx = canvas.getContext('2d')!;
  const PAD = { top: 30, right: 20, bottom: 70, left: 70 };

  function resize() {
    const dpr = window.devicePixelRatio || 1;
    const w = Math.min(
      canvas.parentElement!.getBoundingClientRect().width - 32,
      560
    );
    const h = 300;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    draw(w, h);
  }

  function draw(w: number, h: number) {
    ctx.clearRect(0, 0, w, h);
    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#374151' : '#e5e7eb';
    const labelColor = isDark ? '#9ca3af' : '#6b7280';
    const axisColor = isDark ? '#6b7280' : '#374151';
    const textColor = isDark ? '#f9fafb' : '#111827';

    const chartW = w - PAD.left - PAD.right;
    const chartH = h - PAD.top - PAD.bottom;
    const maxVal = Math.max(...BARS.map((b) => b.value));
    const yMax = Math.ceil(maxVal / 10000) * 10000;
    const barW = (chartW / BARS.length) * 0.55;
    const gap = chartW / BARS.length;

    // Grid lines & Y-axis labels
    const ySteps = 5;
    for (let i = 0; i <= ySteps; i++) {
      const val = (yMax / ySteps) * i;
      const y = h - PAD.bottom - (val / yMax) * chartH;
      ctx.strokeStyle = gridColor;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(PAD.left, y);
      ctx.lineTo(w - PAD.right, y);
      ctx.stroke();
      ctx.fillStyle = labelColor;
      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'right';
      const label =
        val >= 1000
          ? (val / 1000).toLocaleString('vi-VN') + 'K'
          : val.toString();
      ctx.fillText(label, PAD.left - 6, y + 4);
    }

    // Axes
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(PAD.left, PAD.top);
    ctx.lineTo(PAD.left, h - PAD.bottom);
    ctx.lineTo(w - PAD.right, h - PAD.bottom);
    ctx.stroke();

    // Y-axis title
    ctx.save();
    ctx.fillStyle = labelColor;
    ctx.font = '11px system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.translate(14, h / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText('Chi phí (đồng)', 0, 0);
    ctx.restore();

    // Bars + X-axis labels
    for (let i = 0; i < BARS.length; i++) {
      const bar = BARS[i];
      const cx = PAD.left + gap * i + gap / 2;
      const barH = (bar.value / yMax) * chartH;
      const x = cx - barW / 2;
      const y = h - PAD.bottom - barH;

      // Bar
      ctx.fillStyle = bar.color;
      ctx.beginPath();
      const radius = 4;
      ctx.moveTo(x + radius, y);
      ctx.lineTo(x + barW - radius, y);
      ctx.quadraticCurveTo(x + barW, y, x + barW, y + radius);
      ctx.lineTo(x + barW, y + barH);
      ctx.lineTo(x, y + barH);
      ctx.lineTo(x, y + radius);
      ctx.quadraticCurveTo(x, y, x + radius, y);
      ctx.closePath();
      ctx.fill();

      // Value label above bar
      ctx.fillStyle = textColor;
      ctx.font = 'bold 10px system-ui, sans-serif';
      ctx.textAlign = 'center';
      const valLabel =
        bar.value >= 1000
          ? (bar.value / 1000).toLocaleString('vi-VN') + 'K'
          : bar.value.toString();
      ctx.fillText(valLabel, cx, y - 6);

      // X-axis label (multi-line)
      const lines = bar.label.split('\n');
      ctx.fillStyle = labelColor;
      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'center';
      const lineH = 13;
      const startY = h - PAD.bottom + 14;
      for (let l = 0; l < lines.length; l++) {
        ctx.fillText(lines[l], cx, startY + l * lineH);
      }
    }
  }

  function getBar(mx: number, my: number, w: number, h: number): Bar | null {
    const chartW = w - PAD.left - PAD.right;
    const chartH = h - PAD.top - PAD.bottom;
    const maxVal = Math.max(...BARS.map((b) => b.value));
    const yMax = Math.ceil(maxVal / 10000) * 10000;
    const barW = (chartW / BARS.length) * 0.55;
    const gap = chartW / BARS.length;

    for (let i = 0; i < BARS.length; i++) {
      const bar = BARS[i];
      const cx = PAD.left + gap * i + gap / 2;
      const barH = (bar.value / yMax) * chartH;
      const x = cx - barW / 2;
      const y = h - PAD.bottom - barH;

      if (mx >= x && mx <= x + barW && my >= y && my <= h - PAD.bottom) {
        return bar;
      }
    }
    return null;
  }

  function onPointerMove(e: MouseEvent | TouchEvent) {
    const rect = canvas.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    const clientX = e instanceof MouseEvent ? e.clientX : e.touches[0].clientX;
    const clientY = e instanceof MouseEvent ? e.clientY : e.touches[0].clientY;
    const mx = (clientX - rect.left) * (canvas.width / dpr / rect.width);
    const my = (clientY - rect.top) * (canvas.height / dpr / rect.height);
    const w = canvas.width / dpr;
    const h = canvas.height / dpr;
    const hit = getBar(mx, my, w, h);
    if (hit) {
      tooltip.innerHTML = `<strong>${hit.label.replace('\n', ' ')}</strong><br/>${hit.detail}`;
      tooltip.classList.remove('hidden');
      tooltip.style.left = clientX - rect.left + 12 + 'px';
      tooltip.style.top = clientY - rect.top - 50 + 'px';
    } else {
      tooltip.classList.add('hidden');
    }
  }

  canvas.addEventListener('mousemove', onPointerMove);
  canvas.addEventListener(
    'touchmove',
    (e) => {
      e.preventDefault();
      onPointerMove(e);
    },
    { passive: false }
  );
  canvas.addEventListener('mouseleave', () => tooltip.classList.add('hidden'));

  resize();
  window.addEventListener('resize', resize);

  // Re-draw when dark mode toggles
  const observer = new MutationObserver(() => {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.width / dpr;
    const h = canvas.height / dpr;
    draw(w, h);
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });
</script>
