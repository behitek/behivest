---
// src/components/FmarketJourneyTimeline.astro
// Animated onboarding timeline
// Replaces /blog/fmarket-journey-timeline.png

const steps = [
  {
    step: 1,
    title: 'Tải app',
    time: '1 phút',
    icon: '📱',
    detail: "App Store hoặc Google Play → Search 'Fmarket'",
  },
  {
    step: 2,
    title: 'Đăng ký',
    time: '2 phút',
    icon: '📝',
    detail: 'Số điện thoại + xác thực OTP',
  },
  {
    step: 3,
    title: 'eKYC',
    time: '3 phút',
    icon: '📸',
    detail: '2 mặt CCCD/CMND + Selfie xác thực',
  },
  {
    step: 4,
    title: 'Liên kết ngân hàng',
    time: '2 phút',
    icon: '🏦',
    detail: 'VCB, ACB, Techcombank... + xác nhận',
  },
  {
    step: 5,
    title: 'Bắt đầu đầu tư',
    time: '2 phút',
    icon: '🚀',
    detail: 'Browse quỹ → Chọn quỹ → Mua',
  },
];
---

<div
  data-component="fmarket-journey-timeline"
  id="journeyTimeline"
  class="my-8 rounded-2xl border border-gray-200 bg-white p-6 opacity-0 shadow-sm transition-opacity duration-700 dark:border-gray-700 dark:bg-gray-900"
>
  <h3
    class="mb-6 text-center text-lg font-semibold text-gray-800 dark:text-gray-100"
  >
    Mở tài khoản Fmarket trong 10 phút
  </h3>

  <div class="relative mx-auto max-w-sm">
    <!-- Vertical connector line -->
    <div
      class="absolute bottom-0 left-6 top-0 w-0.5 bg-gray-200 dark:bg-gray-700"
    ></div>

    <div class="space-y-6">
      {
        steps.map(({ step, title, time, icon, detail }) => (
          <div class="journey-step relative flex translate-y-4 items-start gap-4 opacity-0 transition-all duration-500">
            <!-- Icon circle -->
            <div class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full border-2 border-emerald-200 bg-emerald-50 text-xl shadow-sm dark:border-emerald-700 dark:bg-emerald-900/30">
              {icon}
            </div>

            <!-- Content -->
            <div class="flex-1 pb-1 pt-1">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-gray-800 dark:text-gray-100">
                  {step}. {title}
                </span>
                <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-medium text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400">
                  {time}
                </span>
              </div>
              <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">
                {detail}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <p
    class="mt-6 text-center text-sm font-medium text-emerald-600 dark:text-emerald-400"
  >
    🎉 Tổng cộng: 10 phút — sẵn sàng mua quỹ đầu tiên!
  </p>
</div>

<script>
  const container = document.querySelector(
    '[data-component="fmarket-journey-timeline"]'
  ) as HTMLElement;
  if (!container) return;

  const steps = container.querySelectorAll<HTMLElement>('.journey-step');

  const io = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        // Fade in container
        container.style.opacity = '1';

        // Stagger each step with 200ms delay
        steps.forEach((step, i) => {
          step.style.transitionDelay = `${i * 200}ms`;
        });
        requestAnimationFrame(() => {
          steps.forEach((step) => {
            step.classList.remove('opacity-0', 'translate-y-4');
            step.classList.add('opacity-100', 'translate-y-0');
          });
        });

        io.disconnect();
      }
    },
    { threshold: 0.2 }
  );

  io.observe(container);
</script>
