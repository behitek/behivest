---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const isLearnActive =
  currentPath.startsWith('/blog') ||
  currentPath.startsWith(`${base}blog`) ||
  currentPath === '/faq' ||
  currentPath === `${base}faq`;

const isActive = (path: string) =>
  currentPath === path || currentPath === `${base}${path.replace(/^\//, '')}`;

const isPathActive = (prefix: string) =>
  currentPath.startsWith(prefix) ||
  currentPath.startsWith(`${base}${prefix.replace(/^\//, '')}`);
---

<header
  id="site-header"
  class="fixed left-0 right-0 top-0 z-40 w-full transition-all duration-300"
  style="border-bottom: 1px solid transparent;"
>
  <nav
    class="mx-auto flex items-center justify-between px-4 py-0 sm:px-6 lg:px-8"
    style="max-width: 1080px; height: 64px;"
  >
    <div class="flex items-center">
      <a
        href={base}
        class="flex items-center space-x-2 font-bold"
        style="color: var(--text); font-size: 20px; letter-spacing: -0.02em;"
      >
        <img src={`${base}logo.svg`} alt="Behivest" class="h-8 w-auto" />
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-button"
      type="button"
      class="inline-flex items-center rounded-lg p-2 text-sm hover:bg-gray-100 focus:outline-none md:hidden"
      style="color: var(--text-muted);"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="sr-only">Mở menu</span>
      <svg
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Desktop menu -->
    <div class="hidden md:flex md:items-center md:gap-6">
      <a
        href={base}
        class="text-sm font-medium transition-colors"
        style={`color: ${isActive('/') ? 'var(--accent)' : 'var(--text)'};`}
      >
        Trang chủ
      </a>

      <!-- Dropdown: Học đầu tư -->
      <div class="relative" id="learn-dropdown-wrapper">
        <button
          id="learn-dropdown-btn"
          type="button"
          class="flex items-center gap-1 text-sm font-medium transition-colors"
          style={`color: ${isLearnActive ? 'var(--accent)' : 'var(--text-secondary)'};`}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Học đầu tư
          <svg
            class="h-4 w-4 transition-transform duration-200"
            id="learn-chevron"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          id="learn-dropdown-menu"
          class="absolute left-0 top-full z-50 mt-2 hidden w-48 py-1"
          style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: 0 8px 24px rgba(0,0,0,0.08);"
        >
          <a
            href={`${base}blog`}
            class="flex items-center gap-2 px-4 py-2.5 text-sm transition-colors"
            style="color: var(--text-secondary);"
            onmouseover="this.style.color='var(--accent)';this.style.background='var(--accent-light)';"
            onmouseout="this.style.color='var(--text-secondary)';this.style.background='transparent';"
          >
            📝 Blog
          </a>
          <a
            href={`${base}faq`}
            class="flex items-center gap-2 px-4 py-2.5 text-sm transition-colors"
            style="color: var(--text-secondary);"
            onmouseover="this.style.color='var(--accent)';this.style.background='var(--accent-light)';"
            onmouseout="this.style.color='var(--text-secondary)';this.style.background='transparent';"
          >
            ❓ FAQ người mới
          </a>
        </div>
      </div>

      <a
        href={`${base}tools`}
        class="text-sm font-medium transition-colors"
        style={`color: ${isPathActive('/tools') ? 'var(--accent)' : 'var(--text-secondary)'};`}
      >
        Công cụ
      </a>
      <a
        href={`${base}performance`}
        class="text-sm font-medium transition-colors"
        style={`color: ${isActive('/performance') ? 'var(--accent)' : 'var(--text-secondary)'};`}
      >
        Hiệu suất quỹ
      </a>
    </div>
    target="_blank" rel="noopener noreferrer" class="rounded-lg px-5 py-2 text-sm
    font-semibold text-white transition-all hover:opacity-90" style="background:
    var(--accent);" > Mở tài khoản
  </nav>
</header>

<!-- Mobile menu -->
<div class="hidden md:hidden" id="mobile-menu">
  <div
    class="space-y-1 border-t px-4 pb-3 pt-2"
    style="border-color: var(--border);"
  >
    <a
      href={base}
      class="block rounded-lg px-3 py-2 text-base font-medium"
      style="color: var(--text);">Trang chủ</a
    >
    <a
      href={`${base}blog`}
      class="block rounded-lg px-3 py-2 text-base font-medium"
      style="color: var(--text-secondary);">📝 Blog</a
    >
    <a
      href={`${base}faq`}
      class="block rounded-lg px-3 py-2 text-base font-medium"
      style="color: var(--text-secondary);">❓ FAQ người mới</a
    >
    <a
      href={`${base}tools`}
      class="block rounded-lg px-3 py-2 text-base font-medium"
      style="color: var(--text-secondary);">Công cụ</a
    >
    <a
      href={`${base}performance`}
      class="block rounded-lg px-3 py-2 text-base font-medium"
      style="color: var(--text-secondary);">Hiệu suất quỹ</a
    >
    <a
      href="https://go.behitek.com/fmarket"
      target="_blank"
      rel="noopener noreferrer"
      class="block rounded-lg px-3 py-2 text-base font-semibold text-white"
      style="background: var(--accent);"
    >
      Mở tài khoản
    </a>
  </div>
</div>

<script>
  const header = document.getElementById('site-header') as HTMLElement | null;

  // Scroll: transparent → frosted glass
  const handleScroll = () => {
    if (!header) return;
    if (window.scrollY > 20) {
      header.style.background = 'rgba(250,250,248,0.92)';
      header.style.backdropFilter = 'blur(12px)';
      header.style.borderBottomColor = 'var(--border)';
    } else {
      header.style.background = 'transparent';
      header.style.backdropFilter = 'none';
      header.style.borderBottomColor = 'transparent';
    }
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileBtn?.addEventListener('click', () => {
    const expanded = mobileBtn.getAttribute('aria-expanded') === 'true';
    mobileBtn.setAttribute('aria-expanded', (!expanded).toString());
    mobileMenu?.classList.toggle('hidden');
  });

  // "Học đầu tư" dropdown
  const learnBtn = document.getElementById('learn-dropdown-btn');
  const learnMenu = document.getElementById('learn-dropdown-menu');
  const learnChevron = document.getElementById('learn-chevron');

  learnBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = learnBtn.getAttribute('aria-expanded') === 'true';
    learnBtn.setAttribute('aria-expanded', (!isOpen).toString());
    learnMenu?.classList.toggle('hidden', isOpen);
    learnChevron?.classList.toggle('rotate-180', !isOpen);
  });

  document.addEventListener('click', () => {
    learnBtn?.setAttribute('aria-expanded', 'false');
    learnMenu?.classList.add('hidden');
    learnChevron?.classList.remove('rotate-180');
  });
</script>
