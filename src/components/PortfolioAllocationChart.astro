---
// src/components/PortfolioAllocationChart.astro
// Portfolio allocation pie chart with 3 preset tabs
// Replaces /blog/fmarket-portfolio-allocation.png
---

<div
  data-component="portfolio-allocation-chart"
  class="my-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-900"
>
  <h3 class="mb-4 text-center text-lg font-semibold text-gray-800 dark:text-gray-100">
    Phân bổ danh mục theo mức độ rủi ro
  </h3>

  <!-- Tabs: Bảo thủ / Cân bằng / Tích cực -->
  <div class="mb-6 flex justify-center gap-2">
    {
      ['Bảo thủ', 'Cân bằng', 'Tích cực'].map((tab, i) => (
        <button
          class="portfolio-tab rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
          data-idx={i}
        >
          {tab}
        </button>
      ))
    }
  </div>

  <!-- Chart + Legend -->
  <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-center">
    <canvas
      id="pieCanvas"
      width="200"
      height="200"
      aria-label="Biểu đồ phân bổ danh mục đầu tư"
      role="img"
    ></canvas>
    <div id="pieLegend" class="flex flex-col gap-3 text-sm"></div>
  </div>

  <!-- Description -->
  <p
    id="pieDesc"
    class="mt-5 text-center text-xs text-gray-500 dark:text-gray-400"
  ></p>
</div>

<script>
  interface Slice {
    label: string;
    pct: number;
    color: string;
  }

  interface Preset {
    name: string;
    slices: Slice[];
    desc: string;
  }

  const PRESETS: Preset[] = [
    {
      name: 'Bảo thủ',
      slices: [
        { label: 'Cổ phiếu', pct: 20, color: '#10b981' },
        { label: 'Trái phiếu', pct: 60, color: '#3b82f6' },
        { label: 'Tiền gửi', pct: 20, color: '#f59e0b' },
      ],
      desc: 'Danh mục bảo thủ: 20% cổ phiếu · 60% trái phiếu · 20% tiền gửi — ưu tiên bảo toàn vốn, rủi ro thấp.',
    },
    {
      name: 'Cân bằng',
      slices: [
        { label: 'Cổ phiếu', pct: 40, color: '#10b981' },
        { label: 'Trái phiếu', pct: 40, color: '#3b82f6' },
        { label: 'Tiền gửi', pct: 20, color: '#f59e0b' },
      ],
      desc: 'Danh mục cân bằng: 40% cổ phiếu · 40% trái phiếu · 20% tiền gửi — hài hoà giữa tăng trưởng và ổn định.',
    },
    {
      name: 'Tích cực',
      slices: [
        { label: 'Cổ phiếu', pct: 70, color: '#10b981' },
        { label: 'Trái phiếu', pct: 20, color: '#3b82f6' },
        { label: 'Tiền gửi', pct: 10, color: '#f59e0b' },
      ],
      desc: 'Danh mục tích cực: 70% cổ phiếu · 20% trái phiếu · 10% tiền gửi — tối đa hoá tăng trưởng, chấp nhận rủi ro cao.',
    },
  ];

  // --- DOM queries (scoped to container) ---
  const container = document.querySelector(
    '[data-component="portfolio-allocation-chart"]'
  ) as HTMLElement;
  if (!container) throw new Error('PortfolioAllocationChart container not found');

  const canvas = container.querySelector('#pieCanvas') as HTMLCanvasElement;
  const tabs = container.querySelectorAll<HTMLButtonElement>('.portfolio-tab');
  const legend = container.querySelector('#pieLegend')!;
  const desc = container.querySelector('#pieDesc')!;

  const ctx = canvas.getContext('2d')!;

  // Apply DPR scaling for crisp rendering on retina screens
  function setupCanvas() {
    const dpr = window.devicePixelRatio || 1;
    const size = 200;
    canvas.width = size * dpr;
    canvas.height = size * dpr;
    canvas.style.width = size + 'px';
    canvas.style.height = size + 'px';
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
  }

  function drawPie(slices: Slice[]) {
    const size = 200;
    const cx = size / 2;
    const cy = size / 2;
    const radius = 80;
    const innerRadius = 38;

    ctx.clearRect(0, 0, size, size);

    let startAngle = -Math.PI / 2;

    for (const slice of slices) {
      const angle = (slice.pct / 100) * 2 * Math.PI;
      const endAngle = startAngle + angle;
      const midAngle = startAngle + angle / 2;

      // Draw slice
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, radius, startAngle, endAngle);
      ctx.closePath();
      ctx.fillStyle = slice.color;
      ctx.fill();
      ctx.strokeStyle = '#ffffff';
      ctx.lineWidth = 2;
      ctx.stroke();

      // Percentage label inside slice
      const labelR = (radius + innerRadius) / 2;
      const lx = cx + Math.cos(midAngle) * labelR;
      const ly = cy + Math.sin(midAngle) * labelR;
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 11px system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(slice.pct + '%', lx, ly);

      startAngle = endAngle;
    }

    // Donut hole
    ctx.beginPath();
    ctx.arc(cx, cy, innerRadius, 0, 2 * Math.PI);
    const isDark = document.documentElement.classList.contains('dark');
    ctx.fillStyle = isDark ? '#111827' : '#ffffff';
    ctx.fill();
  }

  function renderLegend(slices: Slice[]) {
    const isDark = document.documentElement.classList.contains('dark');
    legend.innerHTML = slices
      .map(
        (s) => `
        <div class="flex items-center gap-2">
          <span style="background:${s.color}" class="inline-block h-3 w-3 flex-shrink-0 rounded-full"></span>
          <span class="${isDark ? 'text-gray-300' : 'text-gray-700'} font-medium">${s.label}</span>
          <span class="${isDark ? 'text-gray-400' : 'text-gray-500'}">${s.pct}%</span>
        </div>`
      )
      .join('');
  }

  function setActive(idx: number) {
    const preset = PRESETS[idx];

    // Update tab styles
    tabs.forEach((tab, i) => {
      if (i === idx) {
        tab.className =
          'portfolio-tab rounded-full px-4 py-1.5 text-sm font-medium transition-colors bg-emerald-500 text-white shadow-sm';
      } else {
        tab.className =
          'portfolio-tab rounded-full px-4 py-1.5 text-sm font-medium transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700';
      }
    });

    drawPie(preset.slices);
    renderLegend(preset.slices);
    desc.textContent = preset.desc;
  }

  // Attach tab click handlers
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = Number(tab.dataset.idx);
      setActive(idx);
    });
  });

  // Re-draw donut hole on dark mode toggle
  const observer = new MutationObserver(() => {
    const activeTab = container.querySelector<HTMLButtonElement>('.portfolio-tab[class*="bg-emerald"]');
    if (activeTab) {
      const idx = Number(activeTab.dataset.idx);
      setActive(idx);
    }
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  // Initialise
  setupCanvas();
  setActive(1); // Default: Cân bằng
</script>
