 <section
 id="faq-theo-cum"
 class="border-y border-stone-200 bg-stone-50/70 py-16 sm:py-20"
 >
 <div class="container mx-auto px-4 sm:px-6 lg:px-8">
 <div class="grid gap-10 lg:grid-cols-[0.32fr_0.68fr] lg:items-start">
 <aside class="lg:sticky lg:top-28">
 <p
 class="text-sm font-semibold uppercase tracking-[0.24em] text-primary-700"
 >
 Phần 5
 </p>
 <h2
 class="mt-3 text-3xl font-bold text-stone-900 md:text-4xl"
 >
 FAQ theo cụm câu hỏi
 </h2>
 <p class="mt-4 text-base leading-8 text-stone-600">
 Khi bạn đã có khung hiểu cơ bản, phần này giúp tra nhanh những câu
 hỏi cụ thể hơn mà người mới thường vướng.
 </p>

 <div
 class="mt-6 rounded-[1.75rem] border border-stone-300 bg-[var(--bg-card)] p-5 shadow-sm"
 >
 <p
 class="text-xs font-semibold uppercase tracking-[0.22em] text-stone-500"
 >
 Quy mô hiện tại
 </p>
 <p
 class="mt-3 text-3xl font-semibold text-stone-900"
 >
 {faqCount}
 </p>
 <p class="mt-1 text-sm text-stone-600">
 câu hỏi dành cho người mới, chia thành {faqGroups.length} cụm.
 </p>
 </div>
 </aside>

 <div>
 <div
 class="rounded-[2rem] border border-stone-300 bg-[var(--bg-card)] p-5 shadow-sm"
 >
 <label
 for="faq-search"
 class="text-sm font-medium text-stone-700"
 >
 Tìm theo câu hỏi, khái niệm hoặc tình huống
 </label>
 <div class="relative mt-3">
 <div
 class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-stone-400"
 >
 <svg
 class="h-5 w-5"
 fill="none"
 stroke="currentColor"
 viewBox="0 0 24 24"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="2"
 d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
 </svg>
 </div>
 <input
 id="faq-search"
 type="text"
 placeholder="Ví dụ: có lỗ không, NAV, cần tiền gấp..."
 class="w-full rounded-2xl border border-stone-300 bg-stone-50 py-3 pl-11 pr-4 text-sm text-stone-900 transition-all focus:border-[var(--accent)] focus:outline-none focus:ring-2 focus:ring-primary-200"
 />
 </div>
 <p
 id="faq-result-count"
 class="mt-3 text-sm text-stone-600"
 >
 {faqCount} câu hỏi cho người mới
 </p>
 </div>

 <div
 id="faq-no-results"
 class="mt-6 hidden rounded-[1.75rem] border border-stone-300 bg-[var(--bg-card)] px-6 py-10 text-center text-stone-600 shadow-sm"
 >
 <p class="text-lg font-semibold text-stone-900">
 Không tìm thấy câu hỏi phù hợp.
 </p>
 <p class="mt-2 text-sm">
 Thử lại với từ khóa ngắn hơn như “NAV”, “lỗ”, hoặc “rút tiền”.
 </p>
 </div>

 <div class="mt-6 space-y-5">
 {
 faqGroups.map((group, groupIndex) => (
 <section
 class="rounded-[2rem] border border-stone-300 bg-[var(--bg-card)] shadow-sm"
 data-faq-group
 >
 <div class="border-b border-stone-200 px-6 py-5">
 <div class="flex items-start gap-4">
 <div class="rounded-full bg-[var(--accent)] px-3 py-1 text-sm font-semibold text-white">
 {group.data.icon}
 </div>
 <div>
 <h3 class="text-xl font-semibold text-stone-900">
 {group.data.group}
 </h3>
 {group.data.description && (
 <p class="mt-2 text-sm leading-7 text-stone-600">
 {group.data.description}
 </p>
 )}
 </div>
 </div>
 </div>

 <div class="divide-y divide-stone-200">
 {group.data.items.map((item, itemIndex) => (
 <article
 class="faq-item"
 data-term={item.term.toLowerCase()}
 data-question={item.question.toLowerCase()}
 data-answer={item.answer.toLowerCase()}
 >
 <button
 type="button"
 class="faq-item-toggle w-full px-6 py-5 text-left"
 data-target={`faq-answer-${groupIndex}-${itemIndex}`}
 aria-expanded="false"
 >
 <div class="flex items-start justify-between gap-4">
 <div>
 <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">
 {item.term}
 </p>
 <p class="mt-2 text-base font-medium leading-7 text-stone-900">
 {item.question}
 </p>
 </div>
 <svg
 class="faq-chevron mt-1 h-5 w-5 shrink-0 text-stone-400 transition-transform duration-200"
 fill="none"
 stroke="currentColor"
 viewBox="0 0 24 24"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="2"
 d="M19 9l-7 7-7-7"
 />
 </svg>
 </div>
 </button>

 <div
 id={`faq-answer-${groupIndex}-${itemIndex}`}
 class="faq-answer hidden px-6 pb-6"
 >
 <p class="max-w-3xl text-sm leading-7 text-stone-600">
 {item.answer}
 </p>
 </div>
 </article>
 ))}
 </div>
 </section>
 ))
 }
 </div>
 </div>
 </div>
 </div>
 </section>

 <section class="bg-[var(--bg-card)] py-16 sm:py-20">
 <div class="container mx-auto px-4 sm:px-6 lg:px-8">
 <div class="max-w-3xl">
 <p
 class="text-sm font-semibold uppercase tracking-[0.24em] text-primary-700"
 >
 Đọc tiếp nếu cần
 </p>
 <h2
 class="mt-3 text-3xl font-bold text-stone-900 md:text-4xl"
 >
 Bước tiếp theo, nhưng không cần phải làm ngay
 </h2>
 <p class="mt-4 text-base leading-8 text-stone-600">
 Nếu trang này đã đủ để bạn bình tĩnh hơn và hiểu mình nên hỏi gì tiếp,
 vậy là nó hoàn thành vai trò. Các liên kết dưới đây chỉ là lựa chọn mở
 rộng.
 </p>
 </div>

 <div class="mt-10 grid gap-5 lg:grid-cols-3">
 {
 nextSteps.map((item) => (
 <a
 href={item.href}
 class={`group rounded-[1.75rem] border p-6 transition-all hover:-translate-y-1 hover:shadow-lg ${
 item.subtle
 ?'border-stone-300 bg-stone-50'
 :'border-stone-200 bg-[var(--bg-card)]'
 }`}
 >
 <p class="text-xs font-semibold uppercase tracking-[0.22em] text-stone-500">
 {item.eyebrow}
 </p>
 <h3 class="mt-4 text-xl font-semibold text-stone-900 group-hover:text-primary-700">
 {item.title}
 </h3>
 <p class="mt-3 text-sm leading-7 text-stone-600">
 {item.description}
 </p>
 <span class="mt-5 inline-flex items-center text-sm font-semibold text-primary-700">
 {item.label}
 <svg
 class="ml-2 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
 fill="none"
 stroke="currentColor"
 viewBox="0 0 24 24"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="2"
 d="M9 5l7 7-7 7"
 />
 </svg>
 </span>
 </a>
 ))
 }
 </div>
 </div>
 </section>
</Layout>

<script>
 const faqButtons =
 document.querySelectorAll<HTMLButtonElement>('.faq-item-toggle');
 const faqGroups = document.querySelectorAll<HTMLElement>('[data-faq-group]');
 const faqItems = document.querySelectorAll<HTMLElement>('.faq-item');
 const searchInput = document.getElementById(
'faq-search'
 ) as HTMLInputElement | null;
 const noResults = document.getElementById('faq-no-results');
 const resultCount = document.getElementById('faq-result-count');

 const setFaqItemOpen = (item: HTMLElement, isOpen: boolean) => {
 const button = item.querySelector<HTMLButtonElement>('.faq-item-toggle');
 const answer = item.querySelector<HTMLElement>('.faq-answer');
 const chevron = item.querySelector<SVGElement>('.faq-chevron');

 button?.setAttribute('aria-expanded', isOpen.toString());
 answer?.classList.toggle('hidden', !isOpen);
 chevron?.classList.toggle('rotate-180', isOpen);
 };

 faqButtons.forEach((button) => {
 button.addEventListener('click', () => {
 const targetId = button.dataset.target;
 if (!targetId) return;

 const item = button.closest<HTMLElement>('.faq-item');
 if (!item) return;

 const answer = document.getElementById(targetId);
 const chevron = button.querySelector<SVGElement>('.faq-chevron');
 const isOpen = button.getAttribute('aria-expanded') ==='true';

 button.setAttribute('aria-expanded', (!isOpen).toString());
 answer?.classList.toggle('hidden', isOpen);
 chevron?.classList.toggle('rotate-180', !isOpen);
 });
 });

 searchInput?.addEventListener('input', () => {
 const query = searchInput.value.trim().toLowerCase();
 let visibleCount = 0;

 faqGroups.forEach((group) => {
 const items = group.querySelectorAll<HTMLElement>('.faq-item');
 let groupVisibleCount = 0;

 items.forEach((item) => {
 const term = item.dataset.term ??'';
 const question = item.dataset.question ??'';
 const answer = item.dataset.answer ??'';
 const matches =
 !query ||
 term.includes(query) ||
 question.includes(query) ||
 answer.includes(query);

 item.style.display = matches ?'':'none';
 if (matches) {
 groupVisibleCount += 1;
 }

 if (query) {
 setFaqItemOpen(item, matches);
 } else {
 setFaqItemOpen(item, false);
 }
 });

 group.style.display = groupVisibleCount > 0 ?'':'none';
 visibleCount += groupVisibleCount;
 });

 if (resultCount) {
 resultCount.textContent = query
 ? `${visibleCount} câu hỏi khớp với từ khóa`
 : `${faqItems.length} câu hỏi cho người mới`;
 }

 noResults?.classList.toggle('hidden', visibleCount > 0 || !query);
 });
</script>
