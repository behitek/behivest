---
import Layout from '../layouts/Layout.astro';
import FundPerformance from '../components/FundPerformance.astro';

const title = 'Hiệu suất quỹ mở - Theo dõi và so sánh hiệu suất các quỹ đầu tư';
const description =
  'Theo dõi và so sánh hiệu suất của các quỹ mở tại Việt Nam. Cập nhật NAV mới nhất, lợi nhuận 1 tháng, 1 năm, 3 năm của quỹ cổ phiếu và quỹ trái phiếu.';
const referralUrl = 'https://go.behitek.com/fmarket';
---

<Layout title={title} description={description} image="/performance-hero.jpg">
  <!-- Hero Section -->
  <section
    style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 100px 24px 60px;"
  >
    <div style="max-width: 720px; text-align: center;">
      <div style="margin-bottom: 24px;">
        <span
          style="display: inline-block; padding: 6px 14px; border-radius: 20px; background: var(--accent-light); color: var(--accent); font-size: 13px; font-weight: 600;"
        >
          Cập nhật dữ liệu tự động
        </span>
      </div>
      <h1
        style="font-size: clamp(32px, 5.5vw, 52px); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 24px; text-wrap: balance;"
      >
        Hiệu suất quỹ mở chứng khoán
      </h1>
      <p
        style="font-size: 18px; color: var(--text-secondary); line-height: 1.7; max-width: 560px; margin: 0 auto 40px; text-wrap: pretty;"
      >
        Theo dõi và so sánh hiệu suất thực tế của các quỹ đầu tư tại Việt Nam.
        Tính trực tiếp NAV real-time giúp bạn ra quyết định đầu tư chính xác.
      </p>
      <div
        style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;"
      >
        <a href="#ranking" class="btn-primary">Xem bảng xếp hạng ↓</a>
        <a href="#concepts" class="btn-secondary">Tìm hiểu khái niệm</a>
      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section
    style="background: var(--bg-warm); padding: 48px 24px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);"
  >
    <div
      style="max-width: 800px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 32px; text-align: center;"
    >
      <div>
        <div
          style="font-size: 32px; font-weight: 800; color: var(--accent); letter-spacing: -0.02em;"
        >
          30+
        </div>
        <div
          style="font-size: 14px; color: var(--text-secondary); margin-top: 4px;"
        >
          Hạng mục quỹ mở
        </div>
      </div>
      <div>
        <div
          style="font-size: 32px; font-weight: 800; color: var(--accent); letter-spacing: -0.02em;"
        >
          Real-time
        </div>
        <div
          style="font-size: 14px; color: var(--text-secondary); margin-top: 4px;"
        >
          Dữ liệu NAV cập nhật liên tục
        </div>
      </div>
      <div>
        <div
          style="font-size: 32px; font-weight: 800; color: var(--accent); letter-spacing: -0.02em;"
        >
          2% - 15%
        </div>
        <div
          style="font-size: 14px; color: var(--text-secondary); margin-top: 4px;"
        >
          Biến động mục tiêu từng quỹ
        </div>
      </div>
    </div>
  </section>

  <!-- Explanation & Concepts Section -->
  <section id="concepts" style="padding: 80px 24px;">
    <div style="max-width: 800px; margin: 0 auto;">
      <div style="margin-bottom: 48px;">
        <div
          style="font-size: 13px; font-weight: 600; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 12px;"
        >
          Khái niệm cần biết
        </div>
        <h2
          style="font-size: clamp(24px, 4vw, 36px); font-weight: 700; line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 16px;"
        >
          Hiểu rõ trước khi đọc biểu đồ.
        </h2>
        <p
          style="font-size: 17px; color: var(--text-secondary); line-height: 1.7; max-width: 600px;"
        >
          Hiệu suất quỹ là yếu tố đánh giá chất lượng người quản lý và tiềm năng
          sinh lời. Hãy ghi nhớ vài khái niệm sau.
        </p>
      </div>

      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;"
      >
        {
          [
            {
              title: 'NAV',
              eng: 'Net Asset Value',
              desc: 'Giá trị tài sản ròng mỗi chứng chỉ quỹ. Đây là mức giá bạn mua hoặc bán chứng chỉ quỹ vào cuối mỗi phiên giao dịch.',
            },
            {
              title: 'Quỹ cổ phiếu',
              eng: 'Stock Fund',
              desc: 'Đầu tư chủ yếu vào cổ phiếu. Tiềm năng sinh lời cao hơn nhưng biến động lớn hơn — phù hợp mục tiêu dài hạn 5+ năm.',
            },
            {
              title: 'Quỹ trái phiếu',
              eng: 'Bond Fund',
              desc: 'Đầu tư chủ yếu vào trái phiếu. Ổn định hơn, ít biến động — phù hợp mục tiêu ngắn đến trung hạn 1-3 năm.',
            },
            {
              title: 'Quỹ cân bằng',
              eng: 'Balanced Fund',
              desc: 'Phân bổ vốn vào cả cổ phiếu lẫn trái phiếu để cân bằng rủi ro và lợi nhuận — phù hợp nhà đầu tư trung dung.',
            },
            {
              title: 'Hiệu suất (%)',
              eng: 'Performance',
              desc: 'Phần trăm thay đổi NAV theo kỳ (1 tháng, 1 năm, 3 năm). Số dương = sinh lời, số âm = thua lỗ so với thời điểm ban đầu.',
            },
            {
              title: 'Công ty quản lý quỹ',
              eng: 'Fund Management Company',
              desc: 'Tổ chức chuyên nghiệp quản lý danh mục đầu tư của quỹ. Uy tín và kinh nghiệm của công ty là yếu tố quan trọng khi chọn quỹ.',
            },
          ].map((item, i) => (
            <div class="card" style="padding: 28px;">
              <div style="width: 40px; height: 40px; border-radius: 10px; background: var(--accent-light); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <span style="font-size: 18px; font-weight: 800; color: var(--accent);">
                  {i + 1}
                </span>
              </div>
              <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 4px;">
                {item.title}
              </h3>
              <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 10px; font-weight: 600;">
                {item.eng}
              </p>
              <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.6;">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Fund Performance Tracker Area -->
  <section id="ranking" style="padding: 80px 24px; background: var(--bg-warm);">
    <div style="max-width: 1536px; width: 100%; margin: 0 auto;">
      <div style="margin-bottom: 48px; text-align: center;">
        <h2
          style="font-size: clamp(24px, 4vw, 36px); font-weight: 700; line-height: 1.3; letter-spacing: -0.02em;"
        >
          Bảng xếp hạng hiệu suất
        </h2>
        <p
          style="font-size: 16px; color: var(--text-secondary); margin-top: 12px;"
        >
          So sánh các quỹ với nhau tuỳ thuộc theo mong muốn đầu tư.
        </p>
      </div>

      <!-- React Component Mount Point (No explicit dark modes left, purely inherits layout CSS) -->
      <FundPerformance
        initialFilter="ALL"
        pageSize={999}
        showFilters={true}
        showActionCol={false}
      />
    </div>
  </section>

  <!-- Final CTA Banner -->
  <section
    style="padding: 80px 24px; background: var(--accent); text-align: center;"
  >
    <div style="max-width: 560px; margin: 0 auto;">
      <h2
        style="font-size: clamp(24px, 4vw, 36px); font-weight: 700; color: #fff; letter-spacing: -0.02em; margin-bottom: 16px; text-wrap: balance;"
      >
        Sẵn sàng bắt đầu đầu tư?
      </h2>
      <p
        style="font-size: 16px; color: rgba(255,255,255,0.85); margin-bottom: 32px; line-height: 1.6;"
      >
        Bắt đầu hành trình tài chính của bạn ngay hôm nay với mức rủi ro kiểm
        soát thông qua các quỹ nội địa.
      </p>
      <a
        href={referralUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 8px; background: #fff; color: var(--accent); padding: 16px 36px; border-radius: 10px; font-size: 17px; font-weight: 700; transition: all 0.25s; text-decoration: none;"
        onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(0,0,0,0.2)'"
        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
      >
        Mở tài khoản Fmarket miễn phí →
      </a>
    </div>
  </section>
</Layout>
