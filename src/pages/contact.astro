---
import Layout from'@layouts/Layout.astro';
---

<Layout
 title="Liên hệ"
 description="Liên hệ với Behivest. Chúng tôi luôn sẵn sàng lắng nghe ý kiến, câu hỏi và đóng góp của bạn."
>
 <div
 class="bg-gradient-to-b from-primary-50 to-white py-16"
 >
 <div class="container mx-auto px-4 sm:px-6 lg:px-8">
 <h1 class="text-4xl font-bold text-[var(--text)] md:text-5xl">
 Liên hệ
 </h1>
 <p class="mt-4 text-lg text-[var(--text-secondary)]">
 Chúng tôi rất mong nhận được phản hồi từ bạn
 </p>
 </div>
 </div>

 <div class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
 <div class="mx-auto max-w-3xl">
 <div class="grid gap-8 lg:grid-cols-2">
 <!-- Contact Form -->
 <div class="card">
 <h2 class="text-2xl font-semibold text-[var(--text)]">
 Gửi tin nhắn
 </h2>
 <p class="mt-2 text-sm text-[var(--text-secondary)]">
 Điền thông tin bên dưới và chúng tôi sẽ phản hồi sớm nhất có thể
 </p>

 <!--
 IMPORTANT: Replace YOUR_FORMSPREE_ID with your actual Formspree form ID
 Get one at https://formspree.io/
 -->
 <form
 id="contact-form"
 action="https://formspree.io/f/YOUR_FORMSPREE_ID"
 method="POST"
 class="mt-6 space-y-6"
 >
 <div>
 <label
 for="name"
 class="block text-sm font-medium text-[var(--text-secondary)]"
 >
 Họ và tên <span class="text-red-500">*</span>
 </label>
 <input
 type="text"
 id="name"
 name="name"
 required
 class="mt-1 block w-full rounded-lg border border-gray-300 bg-[var(--bg-card)] px-4 py-2 text-[var(--text)] focus:border-[var(--accent)] focus:ring-[var(--accent)]"
 />
 </div>

 <div>
 <label
 for="email"
 class="block text-sm font-medium text-[var(--text-secondary)]"
 >
 Email <span class="text-red-500">*</span>
 </label>
 <input
 type="email"
 id="email"
 name="email"
 required
 class="mt-1 block w-full rounded-lg border border-gray-300 bg-[var(--bg-card)] px-4 py-2 text-[var(--text)] focus:border-[var(--accent)] focus:ring-[var(--accent)]"
 />
 </div>

 <div>
 <label
 for="subject"
 class="block text-sm font-medium text-[var(--text-secondary)]"
 >
 Tiêu đề
 </label>
 <input
 type="text"
 id="subject"
 name="subject"
 class="mt-1 block w-full rounded-lg border border-gray-300 bg-[var(--bg-card)] px-4 py-2 text-[var(--text)] focus:border-[var(--accent)] focus:ring-[var(--accent)]"
 />
 </div>

 <div>
 <label
 for="message"
 class="block text-sm font-medium text-[var(--text-secondary)]"
 >
 Nội dung <span class="text-red-500">*</span>
 </label>
 <textarea
 id="message"
 name="message"
 rows="6"
 required
 class="mt-1 block w-full rounded-lg border border-gray-300 bg-[var(--bg-card)] px-4 py-2 text-[var(--text)] focus:border-[var(--accent)] focus:ring-[var(--accent)]"
 ></textarea>
 </div>

 <button type="submit" class="btn-primary w-full" id="submit-btn">
 Gửi tin nhắn
 </button>

 <div id="form-status" class="hidden rounded-lg p-4 text-sm"></div>
 </form>
 </div>

 <!-- Contact Info -->
 <div class="space-y-8">
 <div class="card">
 <h2 class="text-2xl font-semibold text-[var(--text)]">
 Thông tin liên hệ
 </h2>
 <div class="mt-6 space-y-4">
 <div class="flex items-start space-x-3">
 <svg
 class="mt-1 h-5 w-5 text-[var(--accent)]"
 fill="none"
 stroke="currentColor"
 viewBox="0 0 24 24"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="2"
 d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
 ></path>
 </svg>
 <div>
 <p class="font-medium text-[var(--text)]">Email</p>
 <a
 href="mailto:hello@behivest.com"
 class="text-[var(--accent)] hover:text-primary-700"
 >
 hello@behivest.com
 </a>
 </div>
 </div>

 <div class="flex items-start space-x-3">
 <svg
 class="mt-1 h-5 w-5 text-[var(--accent)]"
 fill="none"
 stroke="currentColor"
 viewBox="0 0 24 24"
 >
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="2"
 d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
 ></path>
 <path
 stroke-linecap="round"
 stroke-linejoin="round"
 stroke-width="2"
 d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
 </svg>
 <div>
 <p class="font-medium text-[var(--text)]">
 Địa chỉ
 </p>
 <p class="text-[var(--text-secondary)]">
 Thành phố Hồ Chí Minh, Việt Nam
 </p>
 </div>
 </div>
 </div>
 </div>

 <div class="card bg-[var(--accent-light)]">
 <h3 class="font-semibold text-primary-900">
 💡 Bạn cần hỗ trợ?
 </h3>
 <p class="mt-2 text-sm text-primary-800">
 Trước khi liên hệ, hãy thử:
 </p>
 <ul
 class="mt-2 space-y-1 text-sm text-primary-800"
 >
 <li>
 • Đọc các bài viết hướng dẫn trên <a
 href={`${import.meta.env.BASE_URL}blog`}
 class="underline">Blog</a
 >
 </li>
 <li>
 • Sử dụng <a
 href={`${import.meta.env.BASE_URL}tools`}
 class="underline">Công cụ tính toán</a
 >
 </li>
 <li>• Xem phần bình luận trong bài viết</li>
 </ul>
 </div>

 <div class="card">
 <h3 class="font-semibold text-[var(--text)]">
 📢 Theo dõi chúng tôi
 </h3>
 <p class="mt-2 text-sm text-[var(--text-secondary)]">
 Nhận thông tin mới nhất về tài chính và đầu tư
 </p>
 <div class="mt-4 flex space-x-4">
 <a
 href="#"
 class="rounded-lg bg-[var(--bg-warm)] p-3 text-[var(--text-secondary)] transition-colors hover:bg-[var(--accent-light)] hover:text-[var(--accent)]"
 aria-label="Facebook"
 >
 <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
 <path
 d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
 ></path>
 </svg>
 </a>
 <a
 href="#"
 class="rounded-lg bg-[var(--bg-warm)] p-3 text-[var(--text-secondary)] transition-colors hover:bg-[var(--accent-light)] hover:text-[var(--accent)]"
 aria-label="Twitter"
 >
 <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
 <path
 d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
 ></path>
 </svg>
 </a>
 </div>
 </div>
 </div>
 </div>
 </div>
 </div>

 <script>
 const form = document.getElementById('contact-form') as HTMLFormElement;
 const submitBtn = document.getElementById(
'submit-btn'
 ) as HTMLButtonElement;
 const formStatus = document.getElementById('form-status') as HTMLDivElement;

 form?.addEventListener('submit', async (e) => {
 e.preventDefault();

 submitBtn.disabled = true;
 submitBtn.textContent ='Đang gửi...';

 try {
 const formData = new FormData(form);
 const response = await fetch(form.action, {
 method:'POST',
 body: formData,
 headers: {
 Accept:'application/json',
 },
 });

 if (response.ok) {
 formStatus.classList.remove(
'hidden',
'bg-red-50',
'text-red-800',
'',
''
 );
 formStatus.classList.add(
'bg-green-50',
'text-green-800',
'',
''
 );
 formStatus.textContent =
'✓ Cảm ơn bạn! Tin nhắn đã được gửi thành công.';
 form.reset();
 } else {
 throw new Error('Form submission failed');
 }
 } catch {
 formStatus.classList.remove(
'hidden',
'bg-green-50',
'text-green-800',
'',
''
 );
 formStatus.classList.add(
'bg-red-50',
'text-red-800',
'',
''
 );
 formStatus.textContent =
'✗ Có lỗi xảy ra. Vui lòng thử lại sau hoặc gửi email trực tiếp.';
 } finally {
 submitBtn.disabled = false;
 submitBtn.textContent ='Gửi tin nhắn';
 formStatus.classList.remove('hidden');
 }
 });
 </script>
</Layout>
